---
import MainLayout from '../layouts/MainLayout.astro';
import HeroSelector from '../components/HeroSelector.astro';
import Servicios from '../components/Servicios.astro';
import InfoClinic from '../components/InfoClinic.astro';
import TestimonialsSelector from '../components/TestimonialsSelector.astro';
import Contact from '../components/Contact.astro';
import { config } from '../data/config';
---

<MainLayout title={`Clínica Dental Kyomu | Tu sonrisa, nuestra prioridad`} description={config.description}>
  <!-- Hero Section -->
  <HeroSelector />

  <!-- Services / Treatments -->
  <Servicios />

  <!-- Philosophy / Info -->
  <InfoClinic />

  <!-- Testimonials Section -->
  <TestimonialsSelector />

  <!-- Contact & Location -->
  <Contact />
</MainLayout>
