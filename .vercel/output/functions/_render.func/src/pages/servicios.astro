---
import MainLayout from '../layouts/MainLayout.astro';
import Servicios from '../components/Servicios.astro';
import Contact from '../components/Contact.astro';
import { config } from '../data/config';
---

<MainLayout title={`Tratamientos y Servicios | ${config.clinicName}`} description={config.description}>
  <!-- Page Header -->
  <div class="bg-slate-50 border-b border-gray-100 py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-teal-600 font-semibold tracking-wider uppercase text-sm mb-4 block">Tratamientos</span>
      <h1 class="text-4xl md:text-6xl font-bold text-slate-900">Cuidado Dental Integral</h1>
    </div>
  </div>

  <!-- Services Grid -->
  <Servicios />

  <!-- Contact & Appointment -->
  <Contact />
</MainLayout>
