---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';
import HeaderSelector from '../components/HeaderSelector.astro';
import BookingModal from '../components/BookingModal.astro';
import { config } from '../data/config';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Clínica Dental Kyomu | Tu sonrisa, nuestra prioridad", 
  description = "En Clínica Dental Kyomu en Leganés, combinamos tecnología avanzada con un trato humano y cercano. Especialistas en Implantes, Ortodoncia Invisible y Estética Dental." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth" style="color-scheme: light;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    
    <!-- Icons & Fonts -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body class="flex flex-col min-h-dvh font-sans antialiased text-gray-800 bg-white">
    <!-- Header Dinámico de Astro -->
    <HeaderSelector />

    <!-- Main Content -->
    <main class="flex-grow pt-[120px] sm:pt-[130px] md:pt-[140px]">
        <slot />
    </main>

    <!-- Footer Profesional de Astro -->
    <footer class="bg-slate-900 text-white pt-16 pb-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
          <!-- Brand -->
          <div class="col-span-1 md:col-span-1">
            <a href="/" class="flex items-center gap-3 mb-6 group">
              <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center text-teal-400 transition-transform group-hover:scale-110">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2C9 2 7 4 7 8c0 3 1.5 6 3 7 1.5 1 2 2.5 2 4v1a1 1 0 0 0 2 0v-1c0-1.5.5-3 2-4 1.5-1 3-4 3-7 0-4-2-6-5-6z"/>
                </svg>
              </div>
              <span class="font-heading font-bold text-xl text-white uppercase tracking-wider">Kyomu</span>
            </a>
            <p class="text-gray-300 text-sm mb-6 leading-relaxed">
              {config.description}
            </p>
          </div>

          <!-- Links -->
          <div class="col-span-1">
            <h3 class="font-heading font-semibold text-lg mb-6 text-white border-b border-white/10 pb-2">Clínica</h3>
            <ul class="space-y-4 text-sm text-gray-300">
              <li><a href="/nosotros" class="hover:text-teal-400 transition-colors">Sobre Nosotros</a></li>
              <li><a href="/servicios" class="hover:text-teal-400 transition-colors">Tratamientos</a></li>
              <li><a href="/equipo" class="hover:text-teal-400 transition-colors">Nuestro Equipo</a></li>
              <li><a href="/contacto" class="hover:text-teal-400 transition-colors">Contacto</a></li>
            </ul>
          </div>

          <!-- Contact info -->
          <div class="col-span-1">
            <h3 class="font-heading font-semibold text-lg mb-6 text-white border-b border-white/10 pb-2">Contacto</h3>
            <ul class="space-y-4 text-sm text-gray-300">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <span>{config.contact.address}</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-teal-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                <a href={`tel:${config.contact.phone.replace(/\s+/g, '')}`} class="hover:text-teal-400 transition-colors">{config.contact.phone}</a>
              </li>
            </ul>
          </div>

          <!-- Schedule -->
          <div class="col-span-1">
            <h3 class="font-heading font-semibold text-lg mb-6 text-white border-b border-white/10 pb-2">Horario</h3>
            <ul class="space-y-3 text-sm text-gray-300">
              {config.schedule.map((item, index) => (
                <li class={`flex justify-between ${index !== config.schedule.length - 1 ? 'border-b border-white/5 pb-2' : 'pt-1'}`}>
                  <span>{item.day}</span>
                  <span class={`font-medium ${item.closed ? 'text-teal-400' : item.highlight ? 'text-teal-300' : 'text-white'}`}>{item.hours}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-sm text-gray-400">
            &copy; {new Date().getFullYear()} {config.clinicName}. CIF: {config.cif}. Todos los derechos reservados.
          </p>
          <div class="flex flex-wrap gap-4 text-sm mt-4 md:mt-0">
            <a href="/aviso-legal" class="text-gray-400 hover:text-white transition-colors">Aviso Legal</a>
            <a href="/politica-de-privacidad" class="text-gray-400 hover:text-white transition-colors">Política de Privacidad</a>
            <a href="/politica-de-cookies" class="text-gray-400 hover:text-white transition-colors">Política de Cookies</a>
          </div>
        </div>
      </div>
    </footer>

    <CookieBanner />
    <BookingModal />

    <!-- Botones Flotantes de Astro -->
    <div class="fixed bottom-6 right-6 z-[999] flex flex-col gap-4">
      <!-- WhatsApp -->
      <a 
        href={`https://wa.me/34${config.contact.whatsapp.replace(/\s+/g, '')}`} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform active:scale-95 flex items-center justify-center group relative border-2 border-white/20"
        aria-label="Contactar por WhatsApp"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        <span class="absolute right-full mr-4 bg-white text-slate-800 px-4 py-2 rounded-xl text-sm font-bold shadow-xl opacity-0 translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all pointer-events-none whitespace-nowrap border border-gray-100">
          ¿Te ayudamos?
        </span>
      </a>

      <!-- Reserva Cita Modal Trigger -->
      <button 
        class="js-reserva-btn bg-slate-900 text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform active:scale-95 flex items-center justify-center group relative border-2 border-white/20 cursor-pointer"
        aria-label="Reservar Cita"
      >
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="absolute right-full mr-4 bg-white text-slate-800 px-4 py-2 rounded-xl text-sm font-bold shadow-xl opacity-0 translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all pointer-events-none whitespace-nowrap border border-gray-100">
          Pedir Cita
        </span>
      </button>
    </div>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollToPlugin.min.js" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js" is:inline></script>
</body>
</html>
