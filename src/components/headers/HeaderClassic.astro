---
import { config } from '../../data/config';
---
<header class="js-header fixed top-0 left-0 w-full z-[100] bg-white/95 backdrop-blur-md border-b border-gray-100 shadow-sm transition-all duration-300 glass-safari">
  <!-- Top Bar Informativa -->
  <div class="hidden sm:block border-b border-gray-50 bg-slate-50/50 py-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center text-xs font-medium text-gray-500 tracking-wide">
      <div class="flex items-center gap-6">
        <a href={`tel:${config.contact.phone}`} class="flex items-center gap-2 hover:text-teal-600 transition-colors">
          <svg class="w-3.5 h-3.5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 111.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          {config.contact.phone}
        </a>
        <div class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          {config.schedule[0].day}: {config.schedule[0].hours}
        </div>
      </div>
      <div class="flex items-center gap-4 uppercase font-bold text-[10px]">
        Ubicación: <span class="text-slate-800">{config.contact.city}</span>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Logo Left (Dental Premium) -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-teal-50 flex items-center justify-center text-teal-600 transition-transform group-hover:scale-110">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C9 2 7 4 7 8c0 3 1.5 6 3 7 1.5 1 2 2.5 2 4v1a1 1 0 0 0 2 0v-1c0-1.5.5-3 2-4 1.5-1 3-4 3-7 0-4-2-6-5-6z"/>
          </svg>
        </div>
        <div class="flex flex-col">
          <span class="font-heading font-bold text-xl text-slate-900 tracking-[0.1em] uppercase leading-none">Kyomu</span>
          <span class="text-[9px] text-teal-600 font-semibold uppercase tracking-[0.2em] mt-1">Clínica Dental</span>
        </div>
      </a>

      <!-- Desktop Menu Center -->
      <nav class="hidden md:flex space-x-8">
        {config.navigation.map(link => (
          <a href={link.href} class="text-gray-600 hover:text-teal-600 transition-colors font-medium text-sm uppercase tracking-wider">{link.name}</a>
        ))}
      </nav>

      <!-- CTA Right -->
      <div class="hidden md:block">
        <button class="js-reserva-btn inline-flex items-center justify-center px-6 py-2.5 border border-transparent text-sm font-medium rounded-full text-white bg-slate-900 shadow-md shadow-slate-900/10 hover:bg-teal-600 hover:scale-105 transition-all cursor-pointer">
          Pedir Cita
        </button>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button type="button" class="js-mobile-btn text-gray-600 hover:text-teal-600 focus:outline-none p-2" aria-label="Abrir menú">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div class="js-mobile-menu hidden md:hidden bg-white border-t border-gray-100 p-6 space-y-4 shadow-xl">
    {config.navigation.map(link => (
      <a href={link.href} class="block text-gray-700 hover:text-teal-600 transition-colors font-semibold py-2 text-lg border-b border-gray-50">{link.name}</a>
    ))}
    <button class="js-reserva-btn block w-full text-center py-4 bg-slate-900 text-white rounded-xl font-bold mt-4 shadow-md cursor-pointer">Pedir Cita</button>
  </div>
</header>

<style is:global>
  .js-header {
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }
</style>

<script>
  const setupNavigation = () => {
    const btn = document.querySelector('.js-mobile-btn');
    const menu = document.querySelector('.js-mobile-menu');
    
    if (btn && menu) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  };

  setupNavigation();
  document.addEventListener('astro:after-swap', setupNavigation);
</script>
