---
import { config } from '../data/config';
---
<div id="booking-modal" class="fixed inset-0 z-[1000] hidden">
  <!-- Overlay -->
  <div class="absolute inset-0 bg-secondary/60 backdrop-blur-sm js-close-modal"></div>
  
  <!-- Modal Content -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-md bg-white rounded-[2.5rem] shadow-2xl p-8 animate-fade-up">
    <button class="absolute top-6 right-6 text-gray-400 hover:text-secondary js-close-modal" aria-label="Cerrar">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    <div class="text-center mb-8">
      <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-secondary">¿Cómo prefieres reservar?</h3>
      <p class="text-gray-500 mt-2">Elige la opción que más te convenga</p>
    </div>

    <div class="grid gap-4">
      <!-- WhatsApp Option -->
      <a 
        href={`https://wa.me/34${config.contact.whatsapp.replace(/\s+/g, '')}`} 
        target="_blank"
        class="flex items-center gap-4 p-4 rounded-2xl bg-[#25D366]/10 border-2 border-[#25D366]/20 hover:border-[#25D366] transition-all group"
      >
        <div class="w-12 h-12 bg-[#25D366] rounded-xl flex items-center justify-center text-white shadow-lg shadow-[#25D366]/20 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        </div>
        <div class="text-left">
          <span class="block font-bold text-secondary">Vía WhatsApp</span>
          <span class="text-sm text-gray-500">Respuesta rápida</span>
        </div>
      </a>

      <!-- Phone Option -->
      <a 
        href={`tel:${config.contact.phone.replace(/\s+/g, '')}`} 
        class="flex items-center gap-4 p-4 rounded-2xl bg-primary/10 border-2 border-primary/20 hover:border-primary transition-all group"
      >
        <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg shadow-primary/20 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 111.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </div>
        <div class="text-left">
          <span class="block font-bold text-secondary">Llamada Telefónica</span>
          <span class="text-sm text-gray-500">{config.contact.phone}</span>
        </div>
      </a>

      <!-- Doctoralia Option -->
      <a 
        href="https://www.doctoralia.es/ana-marguenda-timon/psicologo/leganes#profile-info" 
        target="_blank"
        class="flex items-center gap-4 p-4 rounded-2xl bg-[#00A9E0]/10 border-2 border-[#00A9E0]/20 hover:border-[#00A9E0] transition-all group"
      >
        <div class="w-12 h-12 bg-[#00A9E0] rounded-xl flex items-center justify-center text-white shadow-lg shadow-[#00A9E0]/20 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
          </svg>
        </div>
        <div class="text-left">
          <span class="block font-bold text-secondary">Reserva Online</span>
          <span class="text-sm text-gray-500">Vía Doctoralia</span>
        </div>
      </a>
    </div>
  </div>
</div>

<script>
  const setupBookingModal = () => {
    const modal = document.getElementById('booking-modal');
    const triggers = document.querySelectorAll('.js-reserva-btn');
    const closers = document.querySelectorAll('.js-close-modal');

    const openModal = (e) => {
      e.preventDefault();
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    };

    triggers.forEach(t => t.addEventListener('click', openModal));
    closers.forEach(c => c.addEventListener('click', closeModal));
  };

  setupBookingModal();
  document.addEventListener('astro:after-swap', setupBookingModal);
</script>
