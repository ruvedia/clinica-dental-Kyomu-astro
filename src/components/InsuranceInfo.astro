<section class="py-12 bg-gray-50/50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="bg-white border-2 border-primary/20 rounded-[2rem] p-10 shadow-sm relative overflow-hidden group hover:border-primary/50 transition-colors">
      <!-- Icono decorativo -->
      <div class="absolute -right-8 -top-8 w-32 h-32 bg-primary/5 rounded-full blur-3xl"></div>
      
      <div class="relative flex flex-col items-center">
        <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-6">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        
        <h3 class="text-2xl font-bold text-secondary mb-4">Información sobre Seguros</h3>
        <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
          <strong>No se aceptan aseguradoras</strong>: se aceptan pacientes privados. Puedes pagar la cita de forma privada, o buscar otro especialista que acepte tu aseguradora.
        </p>
      </div>
    </div>
  </div>
</section>
