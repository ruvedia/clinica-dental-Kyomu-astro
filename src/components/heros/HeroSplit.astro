---
import { config } from '../../data/config';
import { Picture } from 'astro:assets';
---
<section class="relative bg-white min-h-[100svh] !important w-full flex !important flex-col !important justify-start !important items-center !important p-0 !important m-0 !important pt-[110px] sm:pt-[140px] !important pb-10 !important box-border !important overflow-hidden z-[1]" style="-webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-start">
      
      <!-- Image Column (First on Mobile) -->
      <div class="relative lg:h-[600px] rounded-[2.5rem] overflow-hidden shadow-2xl animate-fade-up order-1 lg:order-2" style="animation-delay: 0.2s;">
        <!-- Overlay sutil -->
        <div class="absolute inset-0 z-10 rounded-[2.5rem] pointer-events-none" style="background-color: rgba(13,148,136,0.05) !important;"></div>
        <img 
          src="/img/2024-05-09.jpg" 
          alt="Clínica Dental Kyomu" 
          class="w-full h-full object-cover"
          style="image-rendering: -webkit-optimize-contrast; width: 100% !important; height: 100% !important;"
        />
        <!-- Decorative blob -->
        <div class="absolute -bottom-6 -left-6 w-32 h-32 rounded-full blur-2xl -z-10 pointer-events-none" style="background-color: rgba(13,148,136,0.3) !important;"></div>
      </div>

      <!-- Text Content with CSS Animation (Second on Mobile) -->
      <div class="max-w-2xl relative z-10 animate-fade-up order-2 lg:order-1">
        <span class="animate-safari inline-block py-1.5 px-4 rounded-full font-semibold mb-6 border border-teal-600/20 tracking-wide uppercase bg-teal-50 text-teal-600" style="font-size: 14px !important; line-height: 20px !important;">
          {config.hero.badge}
        </span>
        <h1 class="animate-safari font-bold tracking-tight mb-6 leading-[1.1] text-balance" style="color: #0f172a !important; font-size: clamp(28px, 5vw, 60px) !important; line-height: 1.1 !important;">
          <Fragment set:html={config.hero.title} />
        </h1>
        <p class="animate-safari mb-8 leading-relaxed text-balance" style="color: #4b5563 !important; font-size: 20px !important; line-height: 32px !important;">
          {config.hero.description}
        </p>
        
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4">
          <button class="js-reserva-btn inline-flex items-center justify-center px-8 py-4 border border-transparent font-semibold rounded-full shadow-lg shadow-teal-600/30 w-full sm:w-auto transition-transform hover:scale-105 bg-teal-600 text-white cursor-pointer" style="font-size: 16px !important;">
            Reservar Cita
          </button>
          <a href="/contacto" class="inline-flex items-center justify-center px-8 py-4 border border-gray-200 font-semibold rounded-full bg-white hover:bg-gray-50 shadow-sm transition-all duration-300 w-full sm:w-auto hover:text-teal-600 text-slate-800" style="font-size: 16px !important;">
            Contacto
          </a>
        </div>
      </div>
      
    </div>
  </div>
</section>

<style is:global>
  .hero-split-active {
    opacity: 1 !important;
    visibility: visible !important;
  }
</style>
