---
import { config } from '../../data/config';
import { Picture } from 'astro:assets';
---
<section class="relative bg-white min-h-[100dvh] !important w-full flex !important flex-col !important justify-start !important items-center !important p-0 !important m-0 !important pt-[180px] sm:pt-[200px] !important pb-10 !important box-border !important overflow-hidden z-[1]" style="-webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full animate-fade-up">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
      
      <!-- Interactive Image Side (First on Mobile) -->
      <div class="js-inter-image relative group animate-fade-up order-1 lg:order-2" style="animation-delay: 0.2s;">
        <div class="absolute -inset-4 rounded-[4rem] blur-2xl group-hover:bg-primary/20 transition-colors duration-700 bg-primary/10"></div>
        <div class="relative aspect-[4/5] sm:aspect-square lg:aspect-[4/5] rounded-[3.5rem] overflow-hidden shadow-2xl border-8 border-white">
          <Picture 
            src="/img/fisioprotema/fachada_total.jpg" 
            formats={['avif', 'webp']}
            fallbackFormat="jpg"
            alt="Fachada Clínica Fisioprotema" 
            width={1360}
            height={644}
            class="w-full h-full object-cover"
            style="image-rendering: -webkit-optimize-contrast; width: 100% !important; height: 100% !important;"
          />
        </div>
      </div>

      <!-- Text Side (Second on Mobile) -->
      <div class="relative z-10 order-2 lg:order-1">
        <span class="animate-safari inline-block py-1.5 px-4 rounded-full font-semibold mb-8 border border-primary/20 tracking-wide uppercase bg-primary/10 text-primary" style="font-size: 14px !important; line-height: 20px !important;">
          {config.hero.badge}
        </span>
        
        <h1 class="animate-safari font-bold tracking-tight mb-8 leading-[1.1] text-balance" style="color: #1a1a1a !important; font-size: clamp(28px, 6vw, 70px) !important; line-height: 1.1 !important;">
          <Fragment set:html={config.hero.title} />
        </h1>
        
        <p class="animate-safari mb-10 leading-relaxed text-balance" style="color: #4B5563 !important; font-size: 20px !important; line-height: 32px !important;">
          {config.hero.description}
        </p>
        
        <div class="animate-safari flex flex-col sm:flex-row items-center gap-4">
          <button class="js-reserva-btn inline-flex items-center justify-center px-8 py-4 border border-transparent font-semibold rounded-full shadow-lg shadow-primary/30 w-full sm:w-auto transition-transform hover:scale-105 bg-primary text-white cursor-pointer" style="font-size: 16px !important;">
            Reservar Cita
          </button>
          <a href="/contacto" class="inline-flex items-center justify-center px-8 py-4 border border-gray-200 font-semibold rounded-full bg-white hover:bg-gray-50 shadow-sm transition-all duration-300 w-full sm:w-auto hover:text-primary text-secondary" style="font-size: 16px !important;">
            Contacto
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style is:global>
  .hero-inter-active {
    opacity: 1 !important;
    visibility: visible !important;
  }
</style>

<style is:global>
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(1deg); }
  }
  @keyframes float-ui {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(5px, 10px); }
  }
  .js-inter-image {
    animation: float 6s ease-in-out infinite;
  }
  .js-float-ui {
    animation: float-ui 5s ease-in-out infinite;
  }
</style>
