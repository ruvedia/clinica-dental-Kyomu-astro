---
---
<!-- Cookie Banner Container -->
<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 bg-secondary shadow-[0_-4px_20px_rgba(0,0,0,0.15)] z-[100] transform translate-y-full transition-transform duration-500 ease-out flex opacity-0 hidden">
  <div class="max-w-7xl mx-auto p-4 sm:p-6 flex flex-col md:flex-row items-center justify-between gap-4 w-full">
    
    <div class="text-gray-300 text-sm md:text-base pr-0 md:pr-12 text-center md:text-left">
      Utilizamos cookies propias estrictamente necesarias para el funcionamiento de la web. Puede leer más sobre cómo protegemos sus datos en nuestra 
      <a href="/politica-de-cookies" class="text-white font-medium underline hover:text-primary transition-colors">Política de Cookies</a> y <a href="/politica-de-privacidad" class="text-white font-medium underline hover:text-primary transition-colors">Política de Privacidad</a>.
    </div>

    <div class="flex flex-shrink-0 gap-3 w-full md:w-auto">
      <button id="cookie-accept" class="flex-1 md:flex-none px-6 py-2.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-light transition-colors whitespace-nowrap shadow-md">
        Aceptar todas
      </button>
      <button id="cookie-deny" class="flex-1 md:flex-none px-6 py-2.5 bg-secondary-light text-white font-medium rounded-lg hover:bg-secondary border border-white/20 transition-colors whitespace-nowrap hidden">
        Solo necesarias
      </button> <!-- Botón de denegar pre-oculto para simplicidad a menos que se escale el sistema -->
    </div>

  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const banner = document.getElementById("cookie-banner");
    const acceptBtn = document.getElementById("cookie-accept");

    if (!banner || !acceptBtn) return;

    // Retrasar aparición sutil
    setTimeout(() => {
      if (!localStorage.getItem("gdpr_consent")) {
        banner.classList.remove("hidden");
        // Asegurar reflow antes de la transición CSS
        void banner.offsetWidth;
        banner.classList.remove("translate-y-full", "opacity-0");
      }
    }, 1000);

    acceptBtn.addEventListener("click", () => {
      // Guardar el consentimiento persistente
      localStorage.setItem("gdpr_consent", "true");
      
      // Disparar carga de scripts de analítica/terceros de forma dinámica tras aceptar
      if (typeof window.loadAnalytics === 'function') {
        window.loadAnalytics();
      }

      // Animación de salida
      banner.classList.add("translate-y-full", "opacity-0");
      setTimeout(() => banner.classList.add("hidden"), 500); // match duration
    });
  });
</script>
