---
---
<!-- Botón Flotante para Reabrir Preferencias (Galleta Cookie) -->
<button 
  id="cookie-settings-trigger" 
  class="fixed bottom-6 left-6 z-[999] bg-white text-teal-600 p-4 rounded-full shadow-2xl hover:scale-110 active:scale-95 transition-all duration-300 flex items-center justify-center border-2 border-teal-600/10 cursor-pointer opacity-0 pointer-events-none hover:rotate-12"
  aria-label="Configurar Cookies"
>
  <i class="fas fa-cookie-bite text-2xl animate-pulse"></i>
</button>

<!-- Banner Flotante de Preferencias (Diseño Premium Moderno y RGPD Compliant) -->
<div 
  id="cookie-banner" 
  class="fixed bottom-6 left-6 max-w-md w-[calc(100vw-3rem)] bg-slate-950/95 backdrop-blur-xl border border-white/10 rounded-[2.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.4)] z-[1000] transform translate-y-12 opacity-0 transition-all duration-500 ease-out hidden"
>
  <div class="p-6 sm:p-8">
    <!-- Header banner -->
    <div class="flex items-center gap-4 mb-4">
      <div class="w-12 h-12 bg-teal-500/20 text-teal-400 rounded-2xl flex items-center justify-center flex-shrink-0 animate-bounce-slow">
        <i class="fas fa-cookie text-xl"></i>
      </div>
      <div>
        <h3 class="text-white font-heading font-bold text-lg">Preferencias de Privacidad</h3>
        <p class="text-gray-400 text-xs font-medium">Gestión de cookies de Kyomu</p>
      </div>
    </div>
    
    <!-- Texto descriptivo -->
    <p class="text-gray-300 text-sm leading-relaxed mb-6">
      Utilizamos cookies para garantizar el correcto funcionamiento del sitio y analizar nuestro tráfico. Puede leer más sobre cómo protegemos sus datos en nuestra 
      <a href="/politica-de-cookies" class="text-teal-400 font-semibold underline hover:text-teal-300 transition-colors">Política de Cookies</a> y <a href="/politica-de-privacidad" class="text-teal-400 font-semibold underline hover:text-teal-300 transition-colors">Política de Privacidad</a>.
    </p>

    <!-- Botones de Acción (Tres opciones obligatorias según la AEPD y el RGPD) -->
    <div class="flex flex-col gap-3">
      <div class="flex flex-col sm:flex-row gap-2.5">
        <button 
          id="cookie-accept" 
          class="flex-1 px-5 py-3.5 bg-teal-600 hover:bg-teal-500 text-white font-bold rounded-2xl transition-all text-sm shadow-lg shadow-teal-600/20 cursor-pointer text-center active:scale-98"
        >
          Aceptar todas
        </button>
        <button 
          id="cookie-deny" 
          class="flex-1 px-5 py-3.5 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-2xl border border-white/10 transition-all text-sm cursor-pointer text-center active:scale-98"
        >
          Rechazar todas
        </button>
      </div>
      <button 
        id="cookie-customize-trigger" 
        class="w-full px-5 py-2 bg-transparent hover:text-white text-gray-400 font-semibold transition-all text-xs cursor-pointer text-center hover:underline flex items-center justify-center gap-1.5"
      >
        <span>Personalizar configuración</span>
        <i id="customize-arrow" class="fas fa-chevron-down text-[10px] transition-transform duration-300"></i>
      </button>
    </div>

    <!-- Panel de Personalización Expandible (Oculto inicialmente con animaciones) -->
    <div 
      id="cookie-custom-panel" 
      class="mt-4 pt-4 border-t border-white/10 max-h-0 overflow-hidden opacity-0 transition-all duration-300 ease-in-out"
    >
      <div class="flex flex-col gap-4 mb-5">
        <!-- Cookies Técnicas (Estrictamente Necesarias) -->
        <div class="flex items-start justify-between gap-3 bg-white/5 p-3 rounded-xl border border-white/5">
          <div class="flex-1">
            <h4 class="text-white text-xs font-bold flex items-center gap-1.5">
              <span>Estrictamente Necesarias</span>
              <span class="px-1.5 py-0.5 bg-teal-500/10 text-[9px] text-teal-400 font-semibold rounded-full uppercase tracking-wider">Obligatorio</span>
            </h4>
            <p class="text-[10px] text-gray-400 leading-normal mt-1">Garantizan el funcionamiento correcto, la seguridad, la estabilidad y la accesibilidad del sitio web.</p>
          </div>
          <div class="relative inline-flex items-center cursor-not-allowed pt-0.5">
            <div class="w-8 h-4.5 bg-teal-600 rounded-full flex items-center px-0.5 justify-end">
              <div class="bg-white w-3.5 h-3.5 rounded-full"></div>
            </div>
          </div>
        </div>

        <!-- Cookies de Analíticas -->
        <div class="flex items-start justify-between gap-3 bg-white/5 p-3 rounded-xl border border-white/5">
          <div class="flex-1">
            <h4 class="text-white text-xs font-bold flex items-center gap-1.5">
              <span>Analíticas y Rendimiento</span>
              <span class="px-1.5 py-0.5 bg-white/10 text-[9px] text-gray-300 font-medium rounded-full uppercase tracking-wider">Opcional</span>
            </h4>
            <p class="text-[10px] text-gray-400 leading-normal mt-1">Nos ayudan a entender de forma completamente anónima y estadística cómo interactúan los usuarios con nuestra web.</p>
          </div>
          <label class="relative inline-flex items-center cursor-pointer pt-0.5">
            <input type="checkbox" id="cookie-opt-analytics" class="sr-only peer">
            <div class="w-8 h-4.5 bg-white/10 rounded-full peer peer-focus:ring-0 peer-checked:after:translate-x-[14px] peer-checked:after:border-white after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-3.5 after:w-3.5 after:transition-all peer-checked:bg-teal-600"></div>
          </label>
        </div>
      </div>
      
      <button 
        id="cookie-save-custom" 
        class="w-full px-5 py-3 bg-teal-600 hover:bg-teal-500 text-white font-bold rounded-2xl transition-all text-xs cursor-pointer text-center active:scale-98"
      >
        Guardar mi selección
      </button>
    </div>
  </div>
</div>

<style>
  .animate-bounce-slow {
    animation: bounce-slow 4s infinite ease-in-out;
  }
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const banner = document.getElementById("cookie-banner");
    const acceptBtn = document.getElementById("cookie-accept");
    const denyBtn = document.getElementById("cookie-deny");
    const triggerBtn = document.getElementById("cookie-settings-trigger");
    const customizeTrigger = document.getElementById("cookie-customize-trigger");
    const customPanel = document.getElementById("cookie-custom-panel");
    const arrow = document.getElementById("customize-arrow");
    const saveCustomBtn = document.getElementById("cookie-save-custom");
    const optAnalytics = document.getElementById("cookie-opt-analytics") as HTMLInputElement;

    if (!banner || !acceptBtn || !denyBtn || !triggerBtn || !customizeTrigger || !customPanel || !arrow || !saveCustomBtn || !optAnalytics) return;

    let isPanelOpen = false;

    // Función para mostrar el Banner
    const showBanner = () => {
      triggerBtn.classList.add("opacity-0", "pointer-events-none");
      triggerBtn.classList.remove("opacity-100", "pointer-events-events");
      
      banner.classList.remove("hidden");
      void banner.offsetWidth;
      banner.classList.remove("translate-y-12", "opacity-0");
    };

    // Función para ocultar el Banner
    const hideBanner = () => {
      banner.classList.add("translate-y-12", "opacity-0");
      setTimeout(() => {
        banner.classList.add("hidden");
        triggerBtn.classList.remove("opacity-0", "pointer-events-none");
        triggerBtn.classList.add("opacity-100", "pointer-events-events");
      }, 500);
    };

    // Alternar el panel de personalización
    customizeTrigger.addEventListener("click", () => {
      isPanelOpen = !isPanelOpen;
      if (isPanelOpen) {
        customPanel.classList.remove("max-h-0", "opacity-0");
        customPanel.style.maxHeight = "500px";
        customPanel.style.opacity = "1";
        arrow.style.transform = "rotate(180deg)";
      } else {
        customPanel.style.maxHeight = "0";
        customPanel.style.opacity = "0";
        arrow.style.transform = "rotate(0deg)";
        setTimeout(() => {
          customPanel.classList.add("max-h-0", "opacity-0");
        }, 300);
      }
    });

    // Retrasar aparición inicial si no hay preferencia guardada
    setTimeout(() => {
      if (!localStorage.getItem("gdpr_consent")) {
        showBanner();
      } else {
        triggerBtn.classList.remove("opacity-0", "pointer-events-none");
        triggerBtn.classList.add("opacity-100", "pointer-events-events");
        
        // Sincronizar el checkbox de analíticas en base a la preferencia existente
        const consent = localStorage.getItem("gdpr_consent");
        if (consent === "all" || consent === "analytics") {
          optAnalytics.checked = true;
        } else {
          optAnalytics.checked = false;
        }
      }
    }, 1200);

    // Click Aceptar todas
    acceptBtn.addEventListener("click", () => {
      localStorage.setItem("gdpr_consent", "all");
      optAnalytics.checked = true;
      if (typeof (window as any).loadAnalytics === 'function') {
        (window as any).loadAnalytics();
      }
      hideBanner();
    });

    // Click Rechazar todas
    denyBtn.addEventListener("click", () => {
      localStorage.setItem("gdpr_consent", "denied");
      optAnalytics.checked = false;
      hideBanner();
    });

    // Click Guardar configuración personalizada
    saveCustomBtn.addEventListener("click", () => {
      if (optAnalytics.checked) {
        localStorage.setItem("gdpr_consent", "analytics");
        if (typeof (window as any).loadAnalytics === 'function') {
          (window as any).loadAnalytics();
        }
      } else {
        localStorage.setItem("gdpr_consent", "necessary");
      }
      hideBanner();
    });

    // Click en la Galleta Flotante para reabrir
    triggerBtn.addEventListener("click", () => {
      showBanner();
    });
  });
</script>
